@model Web.Models.GraphicCard

<div class="form__inner">
    <h2 class="form__title">Редактирование видеокарты</h2>
    <form class="form__box" asp-action="UpdateGraphicCard" asp-controller="Catalog" asp-route-id="@Model.Id">
        <div class="form__item">
            <label asp-for="Name">Название</label>
            <input value="@Model.Name" type="text" asp-for="Name" />
        </div>
        <div>
            <label asp-for="Price">Цена</label>
            <input value="@Model.Price" asp-for="Price" type="number" step="0.01" />
        </div>
        <div>
            <label asp-for="ImgSrc">Изображние</label>
            <input value="@Model.ImgSrc" asp-for="ImgSrc" type="file" />
        </div>
        <div>
            <label asp-for="MemoryCapacity">Видеопамять</label>
            <input value="@Model.MemoryCapacity" asp-for="MemoryCapacity" type="number" step="1" />
        </div>
        <div>
        <p>
            <input class="button" type="submit" value="Изменить" />
        </p>
    </form>
</div>